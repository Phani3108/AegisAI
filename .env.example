# Copy to .env and adjust. See README + planning.md.

# Optional: override hybrid routing rules (default: config/routing_policy.yaml in repo)
# AEGISAI_ROUTING_POLICY_PATH=/absolute/path/to/routing_policy.yaml

AEGISAI_OLLAMA_BASE_URL=http://127.0.0.1:11434
AEGISAI_VISION_MODEL=llava
AEGISAI_LLM_MODEL=llama3.2
AEGISAI_EMBED_MODEL=nomic-embed-text
# AEGISAI_MEDIA_ROOT=/safe/read/path

# RAG (document_ref jobs)
# AEGISAI_RAG_CHUNK_SIZE=512
# AEGISAI_RAG_CHUNK_OVERLAP=64
# AEGISAI_RAG_TOP_K=4

# Chroma persistence (default ./data/chroma)
# AEGISAI_CHROMA_PERSIST_DIR=/absolute/path/to/chroma

# OpenTelemetry (install: pip install 'aegisai[otel]')
# AEGISAI_OTEL_ENABLED=false

# Phase 2 — optional API gate (Bearer or X-API-Key on /v1/*)
# AEGISAI_API_KEY=

# Max concurrent pipeline jobs (extra POST /v1/jobs → 429)
# AEGISAI_MAX_CONCURRENT_JOBS=8

# DLP-style regex gate for hybrid jobs (text inputs only; prototype)
# AEGISAI_DLP_ENABLED=false
# AEGISAI_DLP_BLOCK_HYBRID=true

# Optional: long-running vision/LLM calls
# AEGISAI_OLLAMA_TIMEOUT_S=600
